{
  "manifest_version": 3,
  "name": "Anthropic Usage Tracker",
  "version": "1.0.0",
  "description": "Reports claude.ai usage and account limits to the local tracker daemon",

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "webRequest",
    "cookies",
    "alarms",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "*://claude.ai/*",
    "http://127.0.0.1/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Anthropic Usage Tracker"
  }
}
